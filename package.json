{
  "name": "pidron",
  "version": "1.2.1",
  "description": "PIDron desktop drone emulator and PID tuning assistant.",
  "author": "Oleksii \"Kico\" (@Oleksii1221)",
  "license": "MIT",
  "homepage": "https://oleksii1221.github.io/PIDron/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Oleksii1221/PIDron.git"
  },
  "bugs": {
    "url": "https://github.com/Oleksii1221/PIDron/issues"
  },
  "keywords": [
    "drone",
    "pid",
    "quadcopter",
    "betaflight",
    "inav",
    "ardupilot",
    "electron",
    "simulator"
  ],
  "main": "desktop/main.cjs",
  "desktopName": "PIDron",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-packager . PIDron --platform=win32 --arch=x64 --out=dist --overwrite --asar --prune=true --ignore=\"^/dist($|/)\" --ignore=\"^/dist-installer($|/)\" --ignore=\"^/.git($|/)\"",
    "build:linux": "electron-packager . PIDron --platform=linux --arch=x64 --out=dist --overwrite --asar --prune=true --ignore=\"^/dist($|/)\" --ignore=\"^/dist-installer($|/)\" --ignore=\"^/.git($|/)\"",
    "build:all": "npm run build:win && npm run build:linux",
    "build:installer": "electron-builder --win nsis --x64",
    "build:ubuntu": "electron-builder --linux deb --x64 --publish never",
    "build:fedora": "electron-builder --linux rpm --x64 --publish never",
    "build:linux:packages": "electron-builder --linux deb rpm --x64 --publish never"
  },
  "build": {
    "appId": "com.oleksii1221.pidron",
    "productName": "PIDron",
    "copyright": "Copyright (c) 2026 Oleksii \"Kico\"",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "drone3d.js",
      "assets/**/*",
      "desktop/**/*",
      "node_modules/three/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PIDron-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "PIDron",
      "uninstallDisplayName": "PIDron"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "syncDesktopName": true,
      "maintainer": "Oleksii \"Kico\" (@Oleksii1221)",
      "synopsis": "Drone setup simulator and PID tuning workstation",
      "description": "PIDron is a local desktop workstation for drone setup simulation, PID tuning, presets, log analysis, and flight-controller workflows.",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PIDron-${version}-linux-${arch}.${ext}"
    }
  },
  "dependencies": {
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
